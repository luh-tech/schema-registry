{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "version": "1.0.0",
  "$id": "https://schemas.luh.tech/cis/assessment-sync-config.schema.json",
  "title": "Strategic Assessment Sync Configuration",
  "description": "Configuration for syncing Portfolio Strategic Assessment data to Notion dashboards via n8n webhooks.",
  "type": "object",
  "required": [
    "strategicAssessment"
  ],
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "type": "string"
    },
    "$comment": {
      "type": "string"
    },
    "n8nWorkflow": {
      "type": "object",
      "additionalProperties": true,
      "$comment": "TODO: tighten n8n workflow shape — name, description, trigger, nodes observed",
      "properties": {
        "name": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "trigger": {
          "type": "object",
          "additionalProperties": true
        },
        "nodes": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true
          }
        }
      }
    },
    "strategicAssessment": {
      "type": "object",
      "required": [
        "id",
        "title",
        "description",
        "sourceFiles",
        "generator",
        "syncConfig",
        "components",
        "notionSections"
      ],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "notionPageId": {
          "type": "string"
        },
        "sourceFiles": {
          "type": "object",
          "additionalProperties": true,
          "$comment": "TODO: tighten — json and markdown keys observed",
          "properties": {
            "json": {
              "type": "string"
            },
            "markdown": {
              "type": "string"
            }
          }
        },
        "generator": {
          "type": "object",
          "additionalProperties": true,
          "$comment": "TODO: tighten — script, template, executiveSummaryTemplate keys observed",
          "properties": {
            "script": {
              "type": "string"
            },
            "template": {
              "type": "string"
            },
            "executiveSummaryTemplate": {
              "type": "string"
            }
          }
        },
        "syncConfig": {
          "type": "object",
          "required": [
            "enabled",
            "trigger",
            "webhook"
          ],
          "additionalProperties": true,
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "trigger": {
              "type": "string"
            },
            "webhook": {
              "type": "string",
              "format": "uri"
            },
            "notionTargets": {
              "type": "object",
              "additionalProperties": {
                "type": "string"
              }
            }
          }
        },
        "components": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "$comment": "TODO: tighten component shape after stable use",
            "additionalProperties": true
          }
        },
        "notionSections": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "id",
              "type"
            ],
            "additionalProperties": true,
            "$comment": "TODO: tighten section shapes (callout, metrics-row, progress-bars, timeline differ)",
            "properties": {
              "id": {
                "type": "string"
              },
              "type": {
                "type": "string"
              }
            }
          }
        }
      }
    }
  }
}
