{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "urn:luhtech:schema:roadmap-business:v2.1",
  "title": "LuhTech Venture Roadmap Business v2.1",
  "description": "Business-layer data for LuhTech portfolio ventures. v2.1 removes mission, vision, currentStage, and overallProgress — those fields migrated to roadmap.json venture.* (Transform Fabric Architecture v2.0.0, 2026-02-26). ComputedValue financials from v2.2 are preserved. This schema governs all portfolio ventures at schemaVersion 2.2.0 and 2.3.0.",
  "version": "2.1.0",
  "type": "object",
  "required": [
    "$schema",
    "$id",
    "schemaVersion",
    "ventureId",
    "organizationName",
    "lastUpdated",
    "financials",
    "team"
  ],
  "definitions": {
    "source": {
      "type": "object",
      "required": ["name", "type"],
      "properties": {
        "name": { "type": "string" },
        "url": { "type": "string", "format": "uri" },
        "date": { "type": "string" },
        "accessDate": { "type": "string", "format": "date" },
        "type": {
          "type": "string",
          "enum": [
            "verified", "reported", "industry-report", "government-data",
            "comparable", "news", "pilot-data", "internal-calc",
            "internal-estimate", "assumed", "external-research", "internal-ref"
          ]
        },
        "byline": { "type": "string" },
        "comment": { "type": "string" }
      },
      "if": { "properties": { "type": { "enum": ["assumed", "internal-calc"] } } },
      "then": { "required": ["comment"] },
      "additionalProperties": false
    },
    "variable": {
      "type": "object",
      "required": ["id", "label", "value", "unit", "source"],
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" },
        "label": { "type": "string" },
        "value": { "oneOf": [{ "type": "number" }, { "type": "integer" }] },
        "unit": { "type": "string" },
        "source": { "$ref": "#/definitions/source" },
        "asOf": { "type": "string" },
        "confidence": {
          "type": "string",
          "enum": ["verified", "high", "medium", "low", "assumed", "internal"]
        }
      },
      "additionalProperties": false
    },
    "computedValue": {
      "type": "object",
      "required": ["id", "label", "variables", "formula", "result", "resultUnit"],
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" },
        "label": { "type": "string" },
        "description": { "type": "string" },
        "variables": {
          "type": "array",
          "minItems": 0,
          "items": { "$ref": "#/definitions/variable" }
        },
        "formula": { "type": "string" },
        "formulaComment": { "type": "string" },
        "result": { "oneOf": [{ "type": "number" }, { "type": "integer" }] },
        "resultUnit": { "type": "string" },
        "displayValue": { "type": "string" },
        "confidence": {
          "type": "string",
          "enum": ["verified", "high", "medium", "low", "assumed", "internal"]
        },
        "byline": { "type": "string" },
        "lastComputed": { "type": "string", "format": "date-time" }
      },
      "additionalProperties": false
    }
  },
  "properties": {
    "$schema": {
      "type": "string",
      "description": "Schema identifier URN — must be urn:luhtech:schema:roadmap-business:v2.1"
    },
    "$id": {
      "type": "string",
      "pattern": "^urn:luhtech:[a-z][a-z0-9-]*:file:roadmap-business$"
    },
    "schemaVersion": {
      "type": "string",
      "pattern": "^2\\.[0-9]+\\.[0-9]+$",
      "description": "SemVer of the data file. 2.2.0 = ComputedValue for burnRate/TAM/SAM/SOM. 2.3.0 = full ComputedValue coverage."
    },
    "ventureId": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*$"
    },
    "organizationName": { "type": "string" },
    "lastUpdated": { "type": "string", "format": "date-time" },
    "founded": { "type": "string" },
    "industry": { "type": "array", "items": { "type": "string" } },
    "location": { "type": "string" },
    "license": { "type": "string" },
    "financials": {
      "type": "object",
      "description": "Financial data. All quantitative fields are ComputedValues at schemaVersion 2.3.0+. burnRate/TAM/SAM/SOM were ComputedValues from 2.2.0. preSeed/seed/runway/mrr/arr became ComputedValues at 2.3.0.",
      "properties": {
        "preSeed": { "$ref": "#/definitions/computedValue" },
        "preSeedTiming": { "type": "string" },
        "preSeedUse": {
          "type": "object",
          "description": "Allocation of pre-seed proceeds by category. Values are ComputedValues at 2.3.0+.",
          "additionalProperties": true
        },
        "seed": { "$ref": "#/definitions/computedValue" },
        "runway": { "$ref": "#/definitions/computedValue" },
        "burnRate": { "$ref": "#/definitions/computedValue" },
        "mrr": { "$ref": "#/definitions/computedValue" },
        "arr": { "$ref": "#/definitions/computedValue" },
        "totalRaised": { "type": "string" },
        "roundStatus": {
          "type": "string",
          "enum": ["planning", "preparing", "raising", "soft-circling", "closing", "closed"]
        },
        "note": { "type": "string" },
        "pilotValueProjection": {
          "type": "object",
          "properties": {
            "perProject": {},
            "roi": {},
            "paybackPeriod": {}
          }
        }
      }
    },
    "market": {
      "type": "object",
      "description": "Market sizing — TAM → SAM → SOM derivation chain. All figures are ComputedValues.",
      "properties": {
        "tam": { "$ref": "#/definitions/computedValue" },
        "sam": { "$ref": "#/definitions/computedValue" },
        "som": { "$ref": "#/definitions/computedValue" },
        "cagr": { "$ref": "#/definitions/computedValue" },
        "trends": { "type": "array", "items": { "type": "string" } }
      }
    },
    "team": {
      "type": "object",
      "required": ["current"],
      "properties": {
        "current": { "type": "integer", "minimum": 0 },
        "members": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "role"],
            "properties": {
              "name": { "type": "string" },
              "role": { "type": "string" },
              "bio": { "type": "string" },
              "linkedin": { "type": "string", "format": "uri" },
              "expertise": { "type": "array", "items": { "type": "string" } }
            },
            "additionalProperties": false
          }
        },
        "advisors": { "type": "array", "items": { "type": "object" } },
        "contractors": { "type": "array", "items": { "type": "object" } },
        "keyHires": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["role", "quarter"],
            "properties": {
              "role": { "type": "string" },
              "quarter": { "type": "string", "pattern": "^q[1-4]_20[0-9]{2}$" },
              "critical": { "type": "boolean" }
            },
            "additionalProperties": false
          }
        }
      }
    },
    "competitive": {
      "type": "object",
      "properties": {
        "directCompetitors": { "type": "array", "items": { "type": "string" } },
        "indirectCompetitors": { "type": "array", "items": { "type": "string" } },
        "moats": { "type": "array", "items": { "type": "string" } }
      }
    },
    "traction": {
      "type": "object",
      "properties": {
        "customerCount": { "type": "integer", "minimum": 0 },
        "customers": { "type": "array", "items": { "type": "string" } },
        "testimonials": { "type": "array", "items": { "type": "object" } },
        "pilotDetails": {},
        "metrics": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "label": { "type": "string" },
              "value": { "type": "string" },
              "trend": { "type": "string", "enum": ["up", "down", "flat"] }
            }
          }
        }
      }
    },
    "presentation": {
      "type": "object",
      "description": "Human-curated investor deck copy.",
      "properties": {
        "tagline": { "type": "string" },
        "problem": { "type": "object", "additionalProperties": true },
        "solution": { "type": "object", "additionalProperties": true },
        "market": { "type": "object", "additionalProperties": true },
        "businessModel": { "type": "object", "additionalProperties": true },
        "differentiator": { "type": "object", "additionalProperties": true },
        "traction": { "type": "object", "additionalProperties": true },
        "ask": { "type": "object", "additionalProperties": true }
      }
    },
    "assets": {
      "type": "object",
      "properties": {
        "colors": {
          "type": "object",
          "properties": {
            "primary": { "type": "string" },
            "secondary": { "type": "string" },
            "accent": { "type": "string" }
          }
        },
        "fonts": {
          "type": "object",
          "properties": {
            "heading": { "type": "string" },
            "body": { "type": "string" }
          }
        }
      }
    },
    "repositorySplit": {
      "type": "object",
      "properties": {
        "planned": { "type": "boolean" },
        "splitDate": { "type": "string" },
        "publicRepo": { "type": "string" },
        "publicLicense": { "type": "string" },
        "businessRepo": { "type": "string" },
        "businessLicense": { "type": "string" }
      }
    },
    "graphMetadata": {
      "type": "object",
      "properties": {
        "nodeType": { "type": "string", "const": "file" },
        "edges": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "target": { "type": "string" },
              "relationship": { "type": "string" },
              "direction": { "type": "string", "enum": ["outgoing", "incoming"] }
            }
          }
        }
      }
    },
    "meta": {
      "type": "object",
      "properties": {
        "schemaChangelog": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["version", "date", "changes"],
            "properties": {
              "version": { "type": "string" },
              "date": { "type": "string" },
              "changes": { "type": "array", "items": { "type": "string" } }
            },
            "additionalProperties": false
          }
        }
      }
    }
  },
  "additionalProperties": false,
  "x-migrationGuide": {
    "removedFromV2.0": [
      "mission — moved to roadmap.json venture.mission (Transform Fabric Architecture v2.0.0, 2026-02-26)",
      "vision — moved to roadmap.json venture.vision",
      "currentStage — moved to roadmap.json venture.currentStage",
      "overallProgress — moved to roadmap.json venture.overallProgress"
    ],
    "preservedFromV2.2": [
      "financials.burnRate (ComputedValue)",
      "market.tam/sam/som/cagr (ComputedValue)",
      "All team, competitive, traction, presentation sections"
    ],
    "addedAtV2.3": [
      "financials.preSeed, financials.seed, financials.runway, financials.mrr, financials.arr (ComputedValue)",
      "financials.preSeedUse allocations (ComputedValue per category)"
    ]
  },
  "x-changelog": [
    {
      "version": "2.1.0",
      "date": "2026-02-26",
      "changes": [
        "BREAKING: Removed mission, vision, currentStage, overallProgress from schema",
        "These fields migrated to roadmap.json venture.* per Transform Fabric Architecture v2.0.0",
        "ComputedValue financials from v2.2.0 preserved (burnRate, TAM, SAM, SOM)",
        "ComputedValue full coverage from v2.3.0 preserved (preSeed, seed, runway, mrr, arr)"
      ]
    }
  ]
}
