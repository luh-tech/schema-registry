{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://schemas.luh.tech/patent/portfolio.schema.json",
  "title": "Patent Portfolio",
  "description": "Single-source-of-truth horizontal view across all provisionals in a patent portfolio. One file per portfolio (e.g., SBPA). Derived documents (status dashboard, claims cross-reference, kickoff prompts) regenerate from this file.",
  "type": "object",
  "required": ["portfolio", "applicant", "provisionals"],
  "properties": {
    "portfolio": {
      "type": "object",
      "required": ["umbrella", "umbrellaFull", "umbrellaLockedDate"],
      "properties": {
        "umbrella": {
          "type": "string",
          "description": "Short umbrella acronym (e.g., 'SBPA')."
        },
        "umbrellaFull": {
          "type": "string",
          "description": "Full expansion (e.g., 'Spatially-Bound Provenance Architecture')."
        },
        "umbrellaLockedDate": {
          "type": "string",
          "format": "date",
          "description": "Date the umbrella name was locked. If renamed later, the prior name moves to deprecatedAliases."
        },
        "deprecatedAliases": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "deprecatedDate", "reason"],
            "properties": {
              "name": { "type": "string" },
              "full": { "type": "string" },
              "deprecatedDate": { "type": "string", "format": "date" },
              "reason": { "type": "string" }
            }
          },
          "description": "Prior umbrella names retained for cross-reference. Example: CTA → SBPA on 2026-05-05."
        }
      }
    },
    "applicant": {
      "type": "object",
      "required": ["name", "role", "entityStatus", "usptoCustomerNumber"],
      "properties": {
        "name": { "type": "string" },
        "role": {
          "type": "string",
          "enum": ["sole inventor", "joint inventor", "assignee"]
        },
        "entityStatus": {
          "type": "string",
          "enum": ["micro", "small", "large"],
          "description": "USPTO entity status. Determines fee schedule."
        },
        "usptoCustomerNumber": {
          "type": "string",
          "pattern": "^[0-9]{6}$",
          "description": "USPTO Patent Center customer number. Verified via uspto_id.pdf at registration time."
        },
        "usptoCustomerRegistered": {
          "type": "string",
          "format": "date"
        }
      }
    },
    "patentCounsel": {
      "type": "object",
      "properties": {
        "firm": { "type": "string" },
        "role": { "type": "string" },
        "engagementScope": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "priorArtAnchor": {
      "type": "object",
      "description": "§102(b)(1)(A) inventor-exception anchor publications. All provisionals in this portfolio must file before the earliest barDate to preserve the exception.",
      "properties": {
        "inventorException": {
          "type": "string",
          "description": "Statutory citation, e.g., '35 U.S.C. § 102(b)(1)(A)'."
        },
        "npmPackages": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "version", "published", "barDate"],
            "properties": {
              "name": { "type": "string" },
              "version": { "type": "string" },
              "published": { "type": "string", "format": "date" },
              "barDate": {
                "type": "string",
                "format": "date",
                "description": "published + 1 year. Provisional must file on or before this date."
              },
              "verifiedVia": { "type": "string" }
            }
          }
        }
      }
    },
    "relatedPriorPatents": {
      "type": "array",
      "description": "Prior granted patents to the same inventor — context only, not necessarily cross-referenced in any provisional.",
      "items": {
        "type": "object",
        "properties": {
          "patentNumber": { "type": "string" },
          "title": { "type": "string" },
          "shortName": { "type": "string" },
          "inventor": { "type": "string" },
          "granted": { "type": "string" },
          "activeThrough": { "type": "string", "format": "date" },
          "relevance": { "type": "string" }
        }
      }
    },
    "provisionals": {
      "type": "object",
      "patternProperties": {
        "^P[0-9]+$": {
          "$ref": "https://schemas.luh.tech/patent/provisional.schema.json"
        }
      },
      "minProperties": 1,
      "description": "Map of provisional ID (P1, P2, ...) to provisional record."
    },
    "decisionsIndex": {
      "type": "object",
      "patternProperties": {
        "^P[0-9]+$": {
          "type": "object",
          "properties": {
            "log": { "type": "string", "description": "Path to manifest file containing decision log for this provisional." },
            "logSection": { "type": "string" },
            "lockedDecisionsCount": { "type": "integer", "minimum": 0 }
          }
        }
      }
    },
    "toolchain": {
      "type": "object",
      "description": "Versions of pipeline tools used to produce the current portfolio state. Pinned for reproducibility.",
      "additionalProperties": { "type": "string" }
    }
  }
}
