{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "version": "1.0.0",
  "$id": "https://schemas.luh.tech/patent/provisional.schema.json",
  "title": "Patent Provisional Application",
  "description": "Single provisional patent application record. Lives inline in portfolio.yml under provisionals.{P#} and may also be authored standalone as filings/{P#_ShortName}/provisional.yml as the per-provisional source of truth.",
  "type": "object",
  "required": [
    "shortName",
    "cluster",
    "status",
    "filingTarget"
  ],
  "properties": {
    "title": {
      "type": [
        "string",
        "null"
      ],
      "description": "Full provisional title (USPTO submission text). Null while status is 'not-started' or 'in-drafting'; required once status reaches 'filing-ready'."
    },
    "shortName": {
      "type": "string",
      "pattern": "^[A-Za-z][A-Za-z0-9]*$",
      "description": "Single-token CamelCase short name (e.g., 'ProvenanceField', 'TriPulsar'). Used in directory names, filenames, and cross-references."
    },
    "cluster": {
      "type": "string",
      "description": "One-line description of the provisional's subject-matter cluster (used in portfolio overview)."
    },
    "status": {
      "type": "string",
      "enum": [
        "not-started",
        "in-drafting",
        "filing-ready",
        "filed",
        "non-provisional-converted",
        "abandoned"
      ],
      "description": "Lifecycle state. 'filed' is set only after USPTO confirmation receipt is captured in usptoFiling."
    },
    "versionCurrent": {
      "type": "string",
      "pattern": "^v?\\d+\\.\\d+(\\.\\d+)?$"
    },
    "versionLockedDate": {
      "type": "string",
      "format": "date"
    },
    "filingTarget": {
      "type": "string",
      "format": "date",
      "description": "Target USPTO filing date. Must be on or before the earliest barDate in portfolio.priorArtAnchor."
    },
    "filingTargetFlexibility": {
      "type": "string",
      "enum": [
        "hard",
        "slip-flexible",
        "deferred"
      ],
      "description": "Whether filingTarget can slip without escalation. 'hard' = must hit; 'slip-flexible' = inventor approval to slip; 'deferred' = sequencing not yet committed."
    },
    "inventiveStep": {
      "type": "string",
      "description": "Concise plain-language statement of the inventive step. Should match the wherein-clause framing of the lead independent claim."
    },
    "metrics": {
      "type": "object",
      "description": "Quantitative metrics of the current version. Regenerated by spec-builder; do not edit by hand.",
      "properties": {
        "totalWords": {
          "type": "integer",
          "minimum": 0
        },
        "substantiveWords": {
          "type": "integer",
          "minimum": 0
        },
        "pages": {
          "type": "integer",
          "minimum": 0
        },
        "paragraphRange": {
          "type": "string",
          "pattern": "^\\[\\d{3}\\]-\\[\\d{3}\\]$"
        },
        "claimsTotal": {
          "type": "integer",
          "minimum": 0
        },
        "claimsIndependent": {
          "type": "integer",
          "minimum": 0
        },
        "claimsDependent": {
          "type": "integer",
          "minimum": 0
        },
        "figures": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "independentClaims": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "num",
          "scope"
        ],
        "properties": {
          "num": {
            "type": "integer",
            "minimum": 1
          },
          "type": {
            "type": "string",
            "enum": [
              "system",
              "method",
              "apparatus",
              "composition",
              "computer-readable-medium"
            ]
          },
          "scope": {
            "type": "string",
            "description": "One-line scope summary. NOT the claim text itself — claim text lives in spec.md."
          },
          "addedInVersion": {
            "type": "string",
            "description": "Version in which this independent claim was first added (e.g., 'v1.3')."
          }
        }
      }
    },
    "documents": {
      "type": "object",
      "description": "Paths to source-of-truth and built artifacts, relative to the repo root.",
      "properties": {
        "spec": {
          "type": "string",
          "description": "Source .md path."
        },
        "specBuiltDocx": {
          "type": "string",
          "description": "Built .docx path under v{version}/."
        },
        "specBuiltPdf": {
          "type": "string"
        },
        "manifest": {
          "type": "string",
          "description": "Source .yml path."
        },
        "manifestBuiltDocx": {
          "type": "string"
        },
        "figuresSourceDir": {
          "type": "string",
          "description": "Directory containing fig*.svg.js generators."
        },
        "figuresBuiltPdf": {
          "type": "string"
        },
        "glossaryShared": {
          "type": "string",
          "description": "Path to portfolio-shared glossary used by this provisional."
        }
      }
    },
    "relatedInternalDocs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "relevance"
        ],
        "properties": {
          "id": {
            "type": "string",
            "description": "LUHTECH-* document ID."
          },
          "driveId": {
            "type": "string",
            "description": "Optional Google Drive file ID."
          },
          "relevance": {
            "type": "string"
          }
        }
      }
    },
    "crossProvisionalDependencies": {
      "type": "object",
      "description": "Explicit dependencies between provisionals. Bidirectional: providesTo and dependsOn must both be present where applicable so the graph is queryable from either side.",
      "properties": {
        "providesTo": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "target",
              "mechanism"
            ],
            "properties": {
              "target": {
                "type": "string",
                "pattern": "^P[0-9]+$"
              },
              "mechanism": {
                "type": "string"
              }
            }
          }
        },
        "dependsOn": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "target",
              "mechanism"
            ],
            "properties": {
              "target": {
                "type": "string",
                "pattern": "^P[0-9]+$"
              },
              "mechanism": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "conceptionEvidence": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "driveId": {
            "type": "string"
          },
          "date": {
            "type": "string",
            "format": "date"
          }
        }
      }
    },
    "usptoFiling": {
      "type": "object",
      "description": "Populated only after status transitions to 'filed'.",
      "properties": {
        "applicationNumber": {
          "type": "string"
        },
        "filingDate": {
          "type": "string",
          "format": "date"
        },
        "confirmationNumber": {
          "type": "string"
        },
        "receiptPath": {
          "type": "string",
          "description": "Path to USPTO official filing receipt PDF."
        }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "status": {
            "const": "filing-ready"
          }
        },
        "required": [
          "status"
        ]
      },
      "then": {
        "required": [
          "title"
        ],
        "properties": {
          "title": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  ]
}
