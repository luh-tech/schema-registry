{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://schemas.luh.tech/patent/glossary.schema.json",
  "title": "Patent Glossary",
  "description": "Top-level glossary file. Single source of truth for all terminology used across the patent portfolio. The glossary builder reads this and renders sectioned tables to .docx + .md.",
  "type": "object",
  "required": ["documentId", "version", "umbrella", "sections", "entries"],
  "properties": {
    "documentId": {
      "type": "string",
      "pattern": "^LUHTECH-[A-Z0-9-]+$",
      "description": "e.g., 'LUHTECH-PATENT-GLOSSARY-001'."
    },
    "version": {
      "type": "string",
      "pattern": "^v\\d+\\.\\d+(\\.\\d+)?$"
    },
    "lockedDate": {
      "type": "string",
      "format": "date"
    },
    "umbrella": {
      "type": "string",
      "description": "Portfolio umbrella this glossary serves (e.g., 'SBPA')."
    },
    "upstreamCatalog": {
      "type": "object",
      "description": "Pointer to the upstream catalog this glossary defers to for non-patent-owned terms. For SBPA: ACRONYMS-CATALOG-2026-05-04.",
      "properties": {
        "documentId": { "type": "string" },
        "deferralRule": { "type": "string", "description": "Plain-language description of which terms defer to upstream and which are owned by this glossary." }
      }
    },
    "sections": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "title"],
        "properties": {
          "id": { "type": "string", "pattern": "^[A-Z][0-9]?$", "description": "Single capital letter, optional digit (e.g., 'A', 'E2')." },
          "title": { "type": "string" },
          "patentOwned": {
            "type": "boolean",
            "default": false,
            "description": "True if every entry in this section is PATENT-OWNED. Renderer adds the [PATENT-OWNED] badge to the section heading."
          }
        }
      }
    },
    "entries": {
      "type": "array",
      "items": { "$ref": "https://schemas.luh.tech/patent/glossary-entry.schema.json" },
      "minItems": 1
    },
    "changelog": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["version", "date", "summary"],
        "properties": {
          "version": { "type": "string" },
          "date": { "type": "string", "format": "date" },
          "summary": { "type": "string" },
          "addedTerms": { "type": "array", "items": { "type": "string" } },
          "modifiedTerms": { "type": "array", "items": { "type": "string" } },
          "deprecatedTerms": { "type": "array", "items": { "type": "string" } }
        }
      }
    }
  }
}
