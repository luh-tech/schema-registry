{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://schemas.luh.tech/_meta/schema-map.schema.json",
  "title": "LuhTech Schema Map",
  "description": "Schema governing the canonical index of all schemas in luh-tech/schema-registry. Generated by luhtech-schema map; served at https://schemas.luh.tech/_meta/schema-map.json.",
  "version": "1.1.0",
  "type": "object",
  "required": [
    "$schema",
    "streamUrl",
    "version",
    "generatedAt",
    "generatedBy",
    "registry",
    "schemaCount",
    "schemas"
  ],
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "type": "string",
      "format": "uri",
      "pattern": "^https://schemas\\.luh\\.tech/.*\\.schema\\.json$"
    },
    "streamUrl": {
      "type": "string",
      "format": "uri",
      "pattern": "^https://schemas\\.luh\\.tech/.*\\.json$"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+(?:[-+][\\w.-]+)?$"
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "generatedBy": {
      "type": "string"
    },
    "registry": {
      "type": "string"
    },
    "schemaCount": {
      "type": "integer",
      "minimum": 0
    },
    "meta": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "d2Compliant": {
          "type": "integer",
          "minimum": 0
        },
        "d6Compliant": {
          "type": "integer",
          "minimum": 0
        },
        "byLayer": {
          "type": "object",
          "additionalProperties": {
            "type": "integer"
          }
        },
        "bySubdir": {
          "type": "object",
          "additionalProperties": {
            "type": "integer"
          }
        },
        "byRegistry": {
          "type": "object",
          "additionalProperties": {
            "type": "integer"
          }
        }
      }
    },
    "schemas": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "path",
          "subdir",
          "layer",
          "loadable"
        ],
        "additionalProperties": false,
        "properties": {
          "$id": {
            "type": [
              "string",
              "null"
            ]
          },
          "path": {
            "type": "string"
          },
          "version": {
            "type": [
              "string",
              "null"
            ]
          },
          "title": {
            "type": [
              "string",
              "null"
            ]
          },
          "subdir": {
            "type": "string"
          },
          "layer": {
            "type": "string",
            "enum": [
              "vocabulary",
              "governance",
              "infrastructure",
              "portfolio-ops",
              "venture-ops",
              "ip",
              "meta",
              "domain",
              "unclassified"
            ]
          },
          "d2Compliant": {
            "type": "boolean"
          },
          "d6Compliant": {
            "type": "boolean"
          },
          "refCount": {
            "type": "integer",
            "minimum": 0
          },
          "refs": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "loadable": {
            "type": "boolean"
          },
          "loadError": {
            "type": "string"
          }
        }
      }
    }
  }
}
