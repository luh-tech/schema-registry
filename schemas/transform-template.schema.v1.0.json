{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "urn:luhtech:schema:transform-template:v1.0",
  "title": "LuhTech Transform Template Schema v1.0",
  "description": "Governs the format of transform template files (*.transform.v*.json) used by the luhtech-transform engine. Transform templates define field mappings, derivation rules, and provenance configuration for producing output artifacts from canonical source files.",
  "type": "object",
  "required": ["$id", "version", "description", "inputs", "output", "mappings", "provenance"],
  "properties": {
    "$id": {
      "type": "string",
      "pattern": "^urn:luhtech:transforms:[a-z][a-z0-9-]+:v[0-9]+$",
      "description": "URN identifier for this transform template"
    },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$",
      "description": "SemVer version of this transform template"
    },
    "description": {
      "type": "string",
      "description": "Human-readable description of what this transform produces"
    },
    "inputs": {
      "type": "object",
      "description": "Input source definitions",
      "properties": {
        "t1": {
          "$ref": "#/definitions/inputDef"
        },
        "t2": {
          "$ref": "#/definitions/inputDef"
        }
      },
      "required": ["t1"]
    },
    "output": {
      "type": "object",
      "required": ["schema", "description"],
      "properties": {
        "schema": {
          "type": "string",
          "description": "URN of the output schema"
        },
        "description": {
          "type": "string",
          "description": "Human-readable description of the output file"
        }
      }
    },
    "mappings": {
      "type": "array",
      "description": "Field mapping rules — direct pass-through and derived field rules",
      "items": {
        "$ref": "#/definitions/mapping"
      }
    },
    "provenance": {
      "type": "object",
      "required": ["generatedAtField", "sourceHashField", "transformIdField", "transformVersionField", "generatedFromField"],
      "description": "Field paths for provenance metadata injection",
      "properties": {
        "generatedAtField": {"type": "string"},
        "sourceHashField": {"type": "string"},
        "transformIdField": {"type": "string"},
        "transformVersionField": {"type": "string"},
        "generatedFromField": {"type": "string"}
      }
    }
  },
  "definitions": {
    "inputDef": {
      "type": "object",
      "required": ["schema", "required", "description"],
      "properties": {
        "schema": {
          "type": "string",
          "description": "URN of the input schema"
        },
        "required": {
          "type": "boolean",
          "description": "Whether this input is required"
        },
        "description": {
          "type": "string",
          "description": "Human-readable description of this input"
        }
      }
    },
    "mapping": {
      "type": "object",
      "description": "Single field mapping rule",
      "oneOf": [
        {
          "required": ["from", "to"],
          "properties": {
            "from": {
              "type": "string",
              "pattern": "^(t1|t2)\\.",
              "description": "Source field path (t1.* or t2.*)"
            },
            "to": {
              "type": "string",
              "description": "Destination field path in output"
            },
            "transform": {
              "type": "string",
              "description": "Named transform function to apply"
            },
            "args": {
              "type": "object",
              "description": "Arguments for the transform function"
            }
          }
        },
        {
          "required": ["derive", "rule"],
          "properties": {
            "derive": {
              "type": "string",
              "description": "Destination field path for derived value"
            },
            "rule": {
              "type": "string",
              "description": "Derivation rule expression"
            }
          }
        }
      ]
    }
  }
}
