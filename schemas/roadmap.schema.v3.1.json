    "keyMilestone": {
      "type": "object",
      "description": "Critical path milestone (cross-quarter) with URN identifiers and graph metadata for portfolio DAG traversal (enhanced in v2.3)",
      "required": [
        "id",
        "date",
        "event"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*$",
          "description": "Unique milestone ID"
        },
        "urn": {
          "type": "string",
          "pattern": "^urn:luhtech:[a-z][a-z0-9-]*:milestone:[a-z0-9-]+$",
          "description": "URN identifier for graph traversal (added in v2.3)"
        },
        "date": {
          "type": "string",
          "description": "Target date (YYYY-MM-DD or date range)"
        },
        "event": {
          "type": "string",
          "description": "Milestone name"
        },
        "classification": {
          "type": "string",
          "enum": [
            "LEAD",
            "DERIVED",
            "EXTERNAL",
            "FLEXIBLE"
          ],
          "description": "Milestone classification for change cascade analysis (added in v2.3). LEAD = changes cascade downstream, DERIVED = dependent on upstream, EXTERNAL = date set externally, FLEXIBLE = internally adjustable."
        },
        "quarter": {
          "type": "string",
          "pattern": "^q[1-4]_20[0-9]{2}$",
          "description": "Quarter this milestone belongs to"
        },
        "gate": {
          "type": "boolean",
          "default": false,
          "description": "Is this a gate?"
        },
        "critical": {
          "type": "boolean",
          "default": false,
          "description": "Is this critical path?"
        },
        "status": {
          "type": "string",
          "description": "Milestone status"
        },
        "authorityLevel": {
          "type": "integer",
          "minimum": 1,
          "maximum": 7,
          "description": "Authority level required to modify (1-7, added in v2.3). 3=Team Lead, 4=Architect, 5=Owner, 6=Board, 7=External."
        },
        "bufferDays": {
          "type": "integer",
          "minimum": 0,
          "description": "Schedule buffer/float in days (added in v2.3)"
        },
        "graphMetadata": {
          "type": "object",
          "description": "Graph edges for DAG traversal (added in v2.3)",
          "properties": {
            "predecessors": {
              "type": "array",
              "description": "Upstream milestone dependencies",
              "items": {
                "oneOf": [
                  {
                    "type": "string",
                    "description": "Simple URN reference"
                  },
                  {
                    "type": "object",
                    "description": "Detailed dependency edge",
                    "required": [
                      "milestoneUrn"
                    ],
                    "properties": {
                      "milestoneUrn": {
                        "type": "string",
                        "pattern": "^urn:luhtech:[a-z][a-z0-9-]*:milestone:[a-z0-9-]+$"
                      },
                      "relationshipType": {
                        "type": "string",
                        "enum": [
                          "FS",
                          "FF",
                          "SS",
                          "SF"
                        ],
                        "description": "Dependency type (Finish-Start, Finish-Finish, Start-Start, Start-Finish)"
                      },
                      "lagDays": {
                        "type": "integer",
                        "description": "Lag between milestones in days"
                      },
                      "blocking": {
                        "type": "boolean",
                        "description": "Is this a blocking dependency?"
                      }
                    }
                  }
                ]
              }
            },
            "successors": {
              "type": "array",
              "description": "Downstream milestones that depend on this one",
              "items": {
                "oneOf": [
                  {
                    "type": "string",
                    "description": "Simple URN reference"
                  },
                  {
                    "type": "object",
                    "description": "Detailed successor edge",
                    "properties": {
                      "milestoneUrn": {
                        "type": "string"
                      },
                      "relationshipType": {
                        "type": "string"
                      },
                      "lagDays": {
                        "type": "integer"
                      }
                    }
                  }
                ]
              }
            }
          }
        },
        "dependsOn": {
          "type": "array",
          "description": "Legacy: IDs of milestones this depends on (use graphMetadata for v2.3+)",
          "items": {
            "type": "string"
          }
        },
        "evidence": {
          "type": "string",
          "description": "Evidence file reference"
        },
        "commit": {
          "type": "string",
          "description": "Git commit SHA reference"
        },
        "note": {
          "type": "string",
          "description": "Additional context or change notes"
        }
      }
    },
    "advancedFeatures": {
      "type": "object",
