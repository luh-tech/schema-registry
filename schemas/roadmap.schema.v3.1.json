{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "urn:luhtech:schema:roadmap:v3.1",
  "title": "LuhTech Venture Roadmap v3.1",
  "description": "JSON-first roadmap schema for LuhTech portfolio ventures. v3.1.0 adds mission, vision, currentStage, overallProgress to venture.* (moved from roadmap-business.json). v3.0.0 removed financials, team, competitive from roadmap.json \u2014 those fields are now exclusively in roadmap-business.json. Not backward-compatible with v2.x for financials/team fields.",
  "type": "object",
  "required": [
    "$schema",
    "schemaVersion",
    "meta",
    "venture",
    "pitch"
  ],
  "properties": {
    "$schema": {
      "type": "string",
      "description": "Schema identifier",
      "enum": [
        "urn:luhtech:schema:roadmap:v3.1",
        "urn:luhtech:schema:roadmap:v3.0",
        "https://luhtech.dev/schemas/roadmap-v2.json",
        "https://luhtech.dev/schemas/roadmap-v2.3.json",
        "https://luhtech.dev/schemas/roadmap-v2.4.json",
        "luhtechnology-roadmap-v2"
      ]
    },
    "schemaVersion": {
      "type": "string",
      "pattern": "^[23]\\.(0|1|2|3|4)\\.[0-9]+$",
      "description": "SemVer version of the schema being used (2.0.x through 3.1.x)"
    },
    "meta": {
      "$ref": "#/definitions/meta"
    },
    "venture": {
      "$ref": "#/definitions/ventureDetails"
    },
    "pitch": {
      "$ref": "#/definitions/pitch"
    },
    "features": {
      "type": "array",
      "description": "Inline feature catalog with optional references to standalone FEATURE.json specifications (NEW in v2.3, enhanced in v2.4 with featureRef/featureUrn)",
      "items": {
        "$ref": "#/definitions/feature"
      }
    },
    "quarters": {
      "type": "object",
      "description": "Quarterly roadmap data keyed by quarter ID (e.g., 'q4_2025')",
      "patternProperties": {
        "^q[1-4]_20[0-9]{2}$": {
          "$ref": "#/definitions/quarter"
        }
      },
      "additionalProperties": false
    },
    "erikAllocation": {
      "$ref": "#/definitions/erikAllocation"
    },
    "keyMilestones": {
      "type": "array",
      "description": "Critical path milestones across all quarters with graph metadata for DAG traversal",
      "items": {
        "$ref": "#/definitions/keyMilestone"
      }
    },
    "advancedFeatures": {
      "$ref": "#/definitions/advancedFeatures"
    },
    "competitive": {
      "$ref": "#/definitions/competitive"
    },
    "flagshipFeatures": {
      "type": "array",
      "description": "Flagship feature highlights (Ectropy-specific, preserved for backward compatibility)",
      "items": {
        "type": "object"
      }
    },
    "featureSpecifications": {
      "type": "object",
      "description": "Detailed feature specifications (Ectropy-specific, preserved for backward compatibility)",
      "additionalProperties": {
        "type": "object"
      }
    },
    "metricsReporting": {
      "type": "object",
      "description": "Production readiness and CI/CD health metrics",
      "additionalProperties": true
    },
    "completedMilestones": {
      "type": "array",
      "description": "Historical completed milestones",
      "items": {
        "type": "object"
      }
    },
    "crossVentureDependencies": {
      "type": "array",
      "description": "Cross-venture dependency edges for portfolio DAG",
      "items": {
        "$ref": "#/definitions/crossVentureDependency"
      }
    },
    "resources": {
      "type": "object",
      "description": "Resource allocation summary",
      "additionalProperties": true
    },
    "portfolioContext": {
      "type": "object",
      "description": "Portfolio-level context for this venture",
      "additionalProperties": true
    },
    "portfolioDependencies": {
      "type": "object",
      "description": "Portfolio dependency map",
      "additionalProperties": true
    },
    "productTiers": {
      "type": "object",
      "description": "Product tier definitions",
      "additionalProperties": true
    },
    "pilotProject": {
      "type": "object",
      "description": "Pilot project details",
      "additionalProperties": true
    },
    "pilotPartner": {
      "type": "object",
      "description": "Pilot partner details",
      "additionalProperties": true
    },
    "marketContext": {
      "type": "object",
      "description": "Market context and positioning",
      "additionalProperties": true
    },
    "ventureRelationships": {
      "type": "object",
      "description": "Relationships to other portfolio ventures",
      "additionalProperties": true
    },
    "futureVentures": {
      "type": "object",
      "description": "Future venture pipeline",
      "additionalProperties": true
    },
    "materialSystems": {
      "type": "object",
      "description": "Material system tracking",
      "additionalProperties": true
    },
    "infrastructure": {
      "type": "object",
      "description": "Infrastructure inventory",
      "additionalProperties": true
    },
    "_note": {
      "type": "string",
      "description": "Reference to full roadmap location (for summary files)"
    }
  },
  "definitions": {
    "meta": {
      "type": "object",
      "description": "Document metadata",
      "required": [
        "ventureId",
        "ventureName",
        "status"
      ],
      "properties": {
        "ventureId": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*$",
          "description": "Unique venture identifier (lowercase, hyphenated)"
        },
        "ventureName": {
          "type": "string",
          "maxLength": 100,
          "description": "Display name of the venture"
        },
        "lastUpdated": {
          "type": "string",
          "format": "date-time",
          "description": "ISO-8601 timestamp of last update"
        },
        "author": {
          "type": "string",
          "description": "Person who last updated this roadmap"
        },
        "status": {
          "type": "string",
          "enum": [
            "active",
            "paused",
            "archived",
            "draft",
            "planning"
          ],
          "description": "Document status"
        },
        "sourceDoc": {
          "type": "string",
          "description": "Reference to source document or Google Doc"
        },
        "formerName": {
          "type": "string",
          "description": "Previous name of venture (for renamed ventures)"
        },
        "strategicDocuments": {
          "type": "array",
          "description": "References to strategic planning documents",
          "items": {
            "type": "string"
          }
        },
        "syncStatus": {
          "type": "object",
          "description": "Sync status with upstream data sources",
          "properties": {
            "v1Path": {
              "type": "string"
            },
            "lastSync": {
              "type": "string",
              "format": "date-time"
            },
            "syncDirection": {
              "type": "string"
            }
          }
        },
        "schemaChangelog": {
          "type": "array",
          "description": "Schema version changelog for this document",
          "items": {
            "type": "object",
            "required": [
              "version",
              "date",
              "changes"
            ],
            "properties": {
              "version": {
                "type": "string"
              },
              "date": {
                "type": "string"
              },
              "changes": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    },
    "ventureDetails": {
      "type": "object",
      "description": "Venture classification and status",
      "required": [
        "type",
        "architecture"
      ],
      "properties": {
        "type": {
          "oneOf": [
            {
              "type": "string"
            },
            {
              "type": "array",
              "items": {
                "type": "string"
              },
              "minItems": 1
            }
          ],
          "description": "Venture category - single value, compound string, or array of tags"
        },
        "architecture": {
          "type": "string",
          "description": "Primary architecture pattern"
        },
        "forkParent": {
          "type": [
            "string",
            "null"
          ],
          "description": "Parent venture ID if this is a fork (null if not forked)"
        },
        "codeReuse": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100,
          "description": "Percentage of code inherited from parent"
        },
        "platformProgress": {
          "type": "string",
          "description": "Current platform completion percentage (e.g., '96%')"
        },
        "currentPhase": {
          "type": "string",
          "description": "Current development phase (e.g., '5a', '6')"
        },
        "domain": {
          "type": "string",
          "description": "Primary domain"
        },
        "repository": {
          "type": "string",
          "description": "GitHub repository URL"
        },
        "patent": {
          "type": "string",
          "description": "Patent number (if applicable)"
        },
        "patentTitle": {
          "type": "string",
          "description": "Patent title (if applicable)"
        },
        "mission": {
          "type": "string",
          "minLength": 10,
          "description": "Venture mission statement \u2014 visible to team. Moved from roadmap-business.json in v3.1.0."
        },
        "vision": {
          "type": "string",
          "minLength": 10,
          "description": "Venture long-term vision \u2014 visible to team. Moved from roadmap-business.json in v3.1.0."
        },
        "currentStage": {
          "type": "string",
          "enum": [
            "ideation",
            "pre-seed",
            "seed",
            "series-a",
            "series-b",
            "series-c",
            "growth",
            "public"
          ],
          "description": "Current funding/growth stage \u2014 informs team and schedule context. Moved from roadmap-business.json in v3.1.0."
        },
        "overallProgress": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100,
          "description": "Overall roadmap completion percentage (0-100). Moved from roadmap-business.json in v3.1.0."
        }
      }
    },
    "pitch": {
      "type": "object",
      "description": "Investor pitch content",
      "required": [
        "oneLiner",
        "problem",
        "solution",
        "market",
        "differentiator"
      ],
      "properties": {
        "oneLiner": {
          "type": "string",
          "maxLength": 200,
          "description": "Elevator pitch (60-150 chars ideal)"
        },
        "problem": {
          "type": "string",
          "description": "Pain point you solve"
        },
        "solution": {
          "type": "string",
          "description": "Your approach"
        },
        "market": {
          "type": "string",
          "description": "TAM + growth rate"
        },
        "differentiator": {
          "type": "string",
          "description": "Why you win"
        },
        "businessModel": {
          "type": "string",
          "description": "How you make money"
        },
        "traction": {
          "type": "string",
          "description": "Current traction metrics"
        },
        "ask": {
          "type": "string",
          "description": "Funding ask"
        },
        "technology": {
          "type": "string",
          "description": "Technical architecture and technology stack summary"
        }
      }
    },
    "feature": {
      "type": "object",
      "description": "Inline feature entry with optional reference to standalone FEATURE.json specification. The featureRef, featureUrn, and specVersion fields (NEW in v2.4) enable graph traversal from the roadmap to detailed feature specifications.",
      "required": [
        "id",
        "name"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*$",
          "description": "Kebab-case feature identifier"
        },
        "name": {
          "type": "string",
          "description": "Human-readable feature name"
        },
        "category": {
          "type": "string",
          "description": "Feature category (e.g., ai-ml, data-platform, infrastructure, monitoring, hardware)"
        },
        "description": {
          "type": "string",
          "description": "Feature description"
        },
        "status": {
          "type": "string",
          "enum": [
            "planned",
            "in-progress",
            "prototype",
            "concept",
            "beta",
            "complete",
            "deprecated",
            "active"
          ],
          "description": "Feature development status (lowercase roadmap convention)"
        },
        "priority": {
          "type": "integer",
          "minimum": 1,
          "maximum": 4,
          "description": "Priority level (1=CRITICAL, 2=HIGH, 3=MEDIUM, 4=LOW)"
        },
        "visibility": {
          "type": "string",
          "enum": [
            "public",
            "private",
            "internal"
          ],
          "description": "Feature visibility scope"
        },
        "targetReleaseId": {
          "type": "string",
          "description": "Target release version (e.g., 'v1.0.0')"
        },
        "targetQuarter": {
          "type": "string",
          "pattern": "^q[1-4]_20[0-9]{2}$",
          "description": "Target quarter for delivery"
        },
        "icon": {
          "type": "string",
          "description": "Icon identifier for UI rendering"
        },
        "inheritedFrom": {
          "type": [
            "string",
            "null"
          ],
          "description": "Parent venture ID if this feature is inherited/forked"
        },
        "dependsOn": {
          "type": "string",
          "description": "Human-readable dependency note"
        },
        "notes": {
          "type": "string",
          "description": "Additional notes about the feature"
        },
        "progress": {
          "type": "object",
          "description": "Progress tracking details",
          "additionalProperties": true
        },
        "scopeNote": {
          "type": "string",
          "description": "Scope clarification note"
        },
        "subdomainPattern": {
          "type": "string",
          "description": "Subdomain pattern (e.g., '*.job.site')"
        },
        "featureRef": {
          "type": "string",
          "description": "Relative path to FEATURE.json specification file (NEW in v2.4). Enables graph traversal from inline feature entry to full specification.",
          "pattern": "^\\.roadmap/features/[a-z0-9-]+(/[a-z0-9-]+)?/FEATURE\\.json$"
        },
        "featureUrn": {
          "type": "string",
          "description": "URN identifier matching $id in target FEATURE.json (NEW in v2.4). Enables graph traversal without file I/O.",
          "pattern": "^urn:luhtech:[a-z][a-z0-9-]*:feature:[a-z0-9-]+$"
        },
        "specVersion": {
          "type": "string",
          "description": "SemVer of the referenced FEATURE.json specification (NEW in v2.4). Enables cache invalidation when specs change.",
          "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
        },
        "dependsOnFeatures": {
          "type": "array",
          "description": "Feature URNs this feature depends on (NEW in v2.4). Enables feature-to-feature dependency graph edges.",
          "items": {
            "type": "string",
            "pattern": "^urn:luhtech:[a-z][a-z0-9-]*:feature:[a-z0-9-]+$"
          }
        },
        "completionMilestoneId": {
          "type": "string",
          "description": "ID of the keyMilestone that marks feature completion"
        },
        "milestoneUrn": {
          "type": "string",
          "description": "URN of the completion milestone for cross-venture graph traversal (NEW in v2.4)",
          "pattern": "^urn:luhtech:[a-z][a-z0-9-]*:milestone:[a-z0-9-]+$"
        },
        "deliverableIds": {
          "type": "array",
          "description": "IDs of deliverables in quarters that belong to this feature",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "quarter": {
      "type": "object",
      "description": "Single quarter roadmap data",
      "required": [
        "focus"
      ],
      "properties": {
        "focus": {
          "type": "string",
          "description": "Quarter focus area (short title)"
        },
        "theme": {
          "type": "string",
          "description": "Quarter theme (longer description)"
        },
        "status": {
          "type": "string",
          "enum": [
            "planned",
            "active",
            "complete"
          ],
          "description": "Quarter status"
        },
        "phases": {
          "type": "array",
          "description": "Development phases active this quarter",
          "items": {
            "type": "string"
          }
        },
        "milestones": {
          "type": "array",
          "description": "Key milestones for this quarter",
          "items": {
            "$ref": "#/definitions/quarterMilestone"
          }
        },
        "deliverables": {
          "type": "array",
          "description": "Planned deliverables",
          "items": {
            "$ref": "#/definitions/deliverable"
          }
        },
        "metrics": {
          "type": "object",
          "description": "Target metrics for this quarter",
          "additionalProperties": true
        },
        "resources": {
          "type": "object",
          "description": "Resource allocation",
          "properties": {
            "team": {
              "type": [
                "integer",
                "string"
              ],
              "description": "Team size or range"
            },
            "budget": {
              "type": "string",
              "description": "Budget allocation"
            }
          },
          "additionalProperties": true
        },
        "risks": {
          "type": "array",
          "description": "Identified risks",
          "items": {
            "$ref": "#/definitions/risk"
          }
        },
        "dependencies": {
          "type": "array",
          "description": "Dependencies on other ventures or milestones",
          "items": {
            "$ref": "#/definitions/dependency"
          }
        },
        "erikHours": {
          "type": "integer",
          "minimum": 0,
          "maximum": 80,
          "description": "Erik's weekly hours allocated this quarter"
        }
      }
    },
    "quarterMilestone": {
      "type": "object",
      "description": "Milestone within a quarter",
      "required": [
        "event"
      ],
      "properties": {
        "date": {
          "type": "string",
          "format": "date",
          "description": "Target date (YYYY-MM-DD)"
        },
        "event": {
          "type": "string",
          "description": "Milestone name"
        },
        "gate": {
          "type": "boolean",
          "default": false,
          "description": "Is this a gate milestone?"
        },
        "critical": {
          "type": "boolean",
          "default": false,
          "description": "Is this critical path?"
        },
        "status": {
          "type": "string",
          "description": "Milestone status"
        },
        "type": {
          "type": "string",
          "enum": [
            "technical",
            "business",
            "funding",
            "team",
            "launch",
            "ar-milestone"
          ],
          "description": "Milestone category"
        }
      }
    },
    "deliverable": {
      "type": "object",
      "description": "Planned deliverable",
      "required": [
        "name"
      ],
      "properties": {
        "id": {
          "type": "string",
          "description": "Deliverable identifier"
        },
        "name": {
          "type": "string",
          "description": "Deliverable name"
        },
        "owner": {
          "type": "string",
          "default": "team",
          "description": "Person or team responsible"
        },
        "status": {
          "type": "string",
          "enum": [
            "planned",
            "in-progress",
            "complete",
            "blocked",
            "deferred",
            "not-started"
          ],
          "description": "Current status"
        },
        "priority": {
          "oneOf": [
            {
              "type": "integer",
              "minimum": 1,
              "maximum": 5
            },
            {
              "type": "string"
            }
          ],
          "description": "Priority (1=highest, or string like 'critical')"
        },
        "progress": {
          "type": "string",
          "description": "Progress percentage (e.g., '35%')"
        },
        "hours": {
          "type": "integer",
          "minimum": 0,
          "description": "Estimated hours"
        },
        "featureId": {
          "type": "string",
          "description": "Back-reference to owning feature ID (NEW in v2.4)"
        },
        "value": {
          "type": "object",
          "description": "Business value metrics",
          "additionalProperties": true
        },
        "evidence": {
          "type": "array",
          "description": "Evidence file references",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "risk": {
      "type": "object",
      "description": "Identified risk",
      "required": [
        "risk"
      ],
      "properties": {
        "risk": {
          "type": "string",
          "description": "Risk description"
        },
        "probability": {
          "type": "string",
          "enum": [
            "low",
            "medium",
            "medium-high",
            "high",
            "critical",
            "confirmed",
            "resolved"
          ],
          "description": "Likelihood of occurrence"
        },
        "impact": {
          "type": "string",
          "enum": [
            "low",
            "medium",
            "medium-high",
            "high",
            "critical",
            "confirmed",
            "resolved"
          ],
          "description": "Impact if it occurs"
        },
        "mitigation": {
          "type": "string",
          "description": "Mitigation strategy"
        }
      }
    },
    "dependency": {
      "type": "object",
      "description": "Dependency on another venture or milestone",
      "required": [
        "type"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "upstream",
            "downstream",
            "cross-venture",
            "internal",
            "external"
          ],
          "description": "Dependency direction"
        },
        "ventureId": {
          "type": "string",
          "description": "Related venture ID"
        },
        "milestone": {
          "type": "string",
          "description": "Related milestone name"
        },
        "blocking": {
          "type": "boolean",
          "default": false,
          "description": "Is this a blocking dependency?"
        },
        "targetDate": {
          "type": "string",
          "format": "date",
          "description": "Expected completion date"
        }
      }
    },
    "crossVentureDependency": {
      "type": "object",
      "description": "Cross-venture dependency edge for portfolio DAG",
      "required": [
        "from",
        "to",
        "type"
      ],
      "properties": {
        "from": {
          "type": "string",
          "description": "Source venture ID"
        },
        "to": {
          "type": "string",
          "description": "Target venture ID"
        },
        "type": {
          "type": "string",
          "enum": [
            "fork",
            "edge-platform",
            "template",
            "data-source",
            "api-consumer",
            "data-integration",
            "platform-extension"
          ],
          "description": "Dependency type"
        },
        "milestone": {
          "type": "string",
          "description": "Related milestone name"
        },
        "date": {
          "type": "string",
          "description": "Target date or phase"
        },
        "critical": {
          "type": "boolean",
          "description": "Is this a critical dependency?"
        },
        "codeReuse": {
          "type": "string",
          "description": "Code reuse percentage"
        },
        "note": {
          "type": "string",
          "description": "Additional context"
        }
      }
    },
    "financials": {
      "type": "object",
      "description": "Financial planning",
      "properties": {
        "preSeed": {
          "type": [
            "string",
            "null"
          ],
          "description": "Pre-seed funding amount"
        },
        "preSeedTiming": {
          "type": [
            "string",
            "null"
          ],
          "description": "Pre-seed timing (e.g., 'Q2 2026')"
        },
        "preSeedUse": {
          "type": "object",
          "description": "Pre-seed allocation breakdown",
          "additionalProperties": true
        },
        "seed": {
          "type": [
            "string",
            "null"
          ],
          "description": "Seed funding amount"
        },
        "seedTiming": {
          "type": [
            "string",
            "null"
          ],
          "description": "Seed timing"
        },
        "seedUse": {
          "type": "object",
          "description": "Seed allocation breakdown",
          "additionalProperties": true
        },
        "seriesA": {
          "type": [
            "string",
            "null"
          ],
          "description": "Series A target"
        },
        "seriesATiming": {
          "type": [
            "string",
            "null"
          ],
