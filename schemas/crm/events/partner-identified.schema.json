{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://schemas.luh.tech/crm/events/partner-identified.schema.json",
  "title": "Partner Identified",
  "description": "Emitted when a new potential partner is identified for tracking in the Partner pipeline.",
  "version": "1.0.0",
  "type": "object",
  "required": [
    "contactId",
    "identifiedAt",
    "partnerType"
  ],
  "properties": {
    "contactId": {
      "type": "string",
      "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$",
      "description": "Twenty CRM Person UUID"
    },
    "identifiedAt": {
      "type": "string",
      "format": "date-time"
    },
    "partnerType": {
      "type": "string",
      "enum": [
        "technology",
        "channel",
        "implementation",
        "research",
        "academic"
      ]
    },
    "rationale": {
      "type": "string",
      "maxLength": 1000
    }
  },
  "additionalProperties": false
}
