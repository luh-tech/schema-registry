{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://schemas.luh.tech/roadmap.schema.v2.json",
  "title": "LuhTech Venture Roadmap v2",
  "description": "JSON-first roadmap schema for LuhTech portfolio ventures. Supports full venture metadata, quarterly planning, financials, team planning, presentation deck data, and competitive positioning. v2.4.0 adds 39+ missing fields from transformer/component audit.",
  "type": "object",
  "required": [
    "$schema",
    "schemaVersion",
    "meta",
    "venture",
    "pitch"
  ],
  "properties": {
    "$schema": {
      "type": "string",
      "description": "Schema identifier",
      "const": "https://schemas.luh.tech/roadmap.schema.v2.json"
    },
    "schemaVersion": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "SemVer version of the schema being used"
    },
    "meta": {
      "$ref": "#/definitions/meta"
    },
    "venture": {
      "$ref": "#/definitions/ventureDetails"
    },
    "pitch": {
      "$ref": "#/definitions/pitch"
    },
    "quarters": {
      "type": "object",
      "description": "Quarterly roadmap data keyed by quarter ID (e.g., 'q4_2025'). Optional for summary files.",
      "patternProperties": {
        "^q[1-4]_20[0-9]{2}$": {
          "$ref": "#/definitions/quarter"
        }
      },
      "additionalProperties": false
    },
    "financials": {
      "$ref": "#/definitions/financials"
    },
    "team": {
      "$ref": "#/definitions/team"
    },
    "keyMilestones": {
      "type": "array",
      "description": "Critical path milestones across all quarters",
      "items": {
        "$ref": "#/definitions/keyMilestone"
      }
    },
    "competitive": {
      "$ref": "#/definitions/competitive"
    },
    "features": {
      "type": "array",
      "description": "Product features with category, status, and release targeting",
      "items": {
        "$ref": "#/definitions/feature"
      }
    },
    "flagshipFeatures": {
      "type": "array",
      "description": "High-value features with ROI metrics for investor-facing slides",
      "items": {
        "$ref": "#/definitions/flagshipFeature"
      }
    },
    "metricsReporting": {
      "type": "object",
      "description": "Operational metrics: test coverage, production readiness, CI/CD health",
      "properties": {
        "lastUpdated": {
          "type": "string",
          "format": "date-time"
        },
        "productionReadiness": {
          "type": "object",
          "properties": {
            "score": {
              "type": "integer"
            },
            "status": {
              "type": "string"
            }
          }
        },
        "testCoverage": {
          "type": "object",
          "properties": {
            "e2eTestStatus": {
              "type": "object",
              "properties": {
                "totalTests": {
                  "type": "integer"
                }
              }
            }
          }
        },
        "mcpToolStatus": {
          "type": "object",
          "properties": {
            "operational": {
              "type": "integer"
            },
            "specified": {
              "type": "integer"
            }
          }
        }
      },
      "additionalProperties": true
    },
    "traction": {
      "type": "object",
      "description": "Top-level traction data (distinct from pitch.traction string)",
      "properties": {
        "verified": {
          "type": "array",
          "description": "Verified traction proof points",
          "items": {
            "type": "object",
            "properties": {
              "value": {
                "type": "string"
              },
              "metric": {
                "type": "string"
              },
              "evidence": {
                "type": "string"
              }
            }
          }
        }
      },
      "additionalProperties": true
    },
    "presentation": {
      "$ref": "#/definitions/presentation"
    },
    "mcpToolCategories": {
      "type": "array",
      "description": "MCP tool categories for traction slide (venture-specific)",
      "items": {
        "type": "object",
        "properties": {
          "category": {
            "type": "string"
          },
          "tools": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "assets": {
      "type": "object",
      "description": "Brand assets and design tokens",
      "properties": {
        "colors": {
          "type": "object",
          "properties": {
            "primary": {
              "type": "string",
              "description": "Primary brand color (hex)"
            },
            "secondary": {
              "type": "string"
            },
            "accent": {
              "type": "string"
            }
          }
        },
        "fonts": {
          "type": "object",
          "properties": {
            "heading": {
              "type": "string"
            },
            "body": {
              "type": "string"
            }
          }
        }
      }
    },
    "market": {
      "type": "object",
      "description": "Market data with TAM/SAM/SOM (T2)",
      "properties": {
        "tam": {
          "type": "object",
          "additionalProperties": true
        },
        "sam": {
          "type": "object",
          "additionalProperties": true
        },
        "som": {
          "type": "object",
          "additionalProperties": true
        },
        "industrySize": {
          "type": [
            "object",
            "string",
            "null"
          ],
          "description": "Industry size metric"
        },
        "trends": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": true
    }
  },
  "definitions": {
    "meta": {
      "type": "object",
      "description": "Document metadata",
      "required": [
        "ventureId",
        "ventureName",
        "status"
      ],
      "properties": {
        "ventureId": {
          "$ref": "https://schemas.luh.tech/_enums/luhtech-enums.schema.json#/definitions/ventureIdPattern",
          "description": "Unique venture identifier (lowercase, hyphenated)"
        },
        "ventureName": {
          "type": "string",
          "maxLength": 100,
          "description": "Display name of the venture"
        },
        "lastUpdated": {
          "type": "string",
          "format": "date-time",
          "description": "ISO-8601 timestamp of last update"
        },
        "author": {
          "type": "string",
          "description": "Person who last updated this roadmap"
        },
        "status": {
          "$ref": "https://schemas.luh.tech/_enums/luhtech-enums.schema.json#/definitions/documentStatus",
          "description": "Document status"
        },
        "sourceDoc": {
          "type": "string",
          "description": "Reference to source document or Google Doc"
        }
      }
    },
    "ventureDetails": {
      "type": "object",
      "description": "Venture classification and status",
      "required": [
        "type",
        "architecture"
      ],
      "properties": {
        "type": {
          "oneOf": [
            {
              "type": "string",
              "description": "Single venture type or compound type (e.g., 'Hardware + SaaS')"
            },
            {
              "type": "array",
              "items": {
                "type": "string"
              },
              "minItems": 1,
              "description": "Array of venture type tags"
            }
          ],
          "description": "Venture category - single value, compound string, or array of tags"
        },
        "architecture": {
          "$ref": "https://schemas.luh.tech/_enums/luhtech-enums.schema.json#/definitions/architecture",
          "description": "Primary architecture pattern"
        },
        "forkParent": {
          "type": [
            "string",
            "null"
          ],
          "description": "Parent venture ID if this is a fork (null if not forked)"
        },
        "codeReuse": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100,
          "description": "Percentage of code inherited from parent"
        },
        "platformProgress": {
          "type": "string",
          "description": "Current platform completion percentage (e.g., '96%')"
        },
        "currentPhase": {
          "type": "string",
          "description": "Current development phase (e.g., '5a', '6')"
        },
        "domain": {
          "type": "string",
          "format": "hostname",
          "description": "Primary domain"
        }
      }
    },
    "pitch": {
      "type": "object",
      "description": "Investor pitch content \u2014 fields may be strings (summary) or objects (structured)",
      "required": [
        "oneLiner"
      ],
      "properties": {
        "oneLiner": {
          "type": "string",
          "maxLength": 200,
          "description": "Elevator pitch (60-150 chars ideal)"
        },
        "missionLine": {
          "type": "string",
          "description": "Brand signature line (rendered on cover slide footer)"
        },
        "mantra": {
          "type": "string",
          "description": "Venture mantra (used as solution subtitle, ask closing)"
        },
        "problem": {
          "oneOf": [
            {
              "type": "string"
            },
            {
              "type": "object",
              "properties": {
                "headline": {
                  "type": "string"
                },
                "subheadline": {
                  "type": "string"
                },
                "bullets": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                },
                "problemColumns": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "header": {
                        "type": "string"
                      },
                      "bullets": {
                        "type": "array",
                        "items": {
                          "type": "string"
                        }
                      }
                    }
                  }
                }
              }
            }
          ],
          "description": "Pain point \u2014 string summary or structured object with headline/bullets/columns"
        },
        "solution": {
          "oneOf": [
            {
              "type": "string"
            },
            {
              "type": "object",
              "properties": {
                "bullets": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                }
              }
            }
          ],
          "description": "Your approach \u2014 string summary or object with bullets"
        },
        "market": {
          "oneOf": [
            {
              "type": "string"
            },
            {
              "type": "object",
              "properties": {
                "headline": {
                  "type": "string"
                },
                "tam": {
                  "type": "object",
                  "additionalProperties": true
                },
                "sam": {
                  "type": "object",
                  "additionalProperties": true
                },
                "som": {
                  "type": "object",
                  "additionalProperties": true
                },
                "growthRate": {
                  "type": "string"
                }
              }
            }
          ],
          "description": "TAM + growth rate \u2014 string summary or structured market data"
        },
        "differentiator": {
          "type": "string",
          "description": "Why you win"
        },
        "businessModel": {
          "oneOf": [
            {
              "type": "string"
            },
            {
              "type": "object",
              "properties": {
                "revenueModel": {
                  "type": "string"
                }
              }
            }
          ],
          "description": "How you make money"
        },
        "traction": {
          "oneOf": [
            {
              "type": "string"
            },
            {
              "type": "object",
              "properties": {
                "headline": {
                  "type": "string"
                },
                "metrics": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "additionalProperties": true
                  }
                },
                "heroes": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "additionalProperties": true
                  }
                },
                "categoriesText": {
                  "type": "string"
                }
              }
            }
          ],
          "description": "Current traction metrics"
        },
        "ask": {
          "oneOf": [
            {
              "type": "string"
            },
            {
              "type": "object",
              "properties": {
                "amount": {
                  "type": "string"
                },
                "useOfFunds": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "additionalProperties": true
                  }
                },
                "milestones": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "additionalProperties": true
                  }
                }
              }
            }
          ],
          "description": "Funding ask"
        },
        "coverStat": {
          "type": "object",
          "description": "Hero stat for cover slide",
          "properties": {
            "value": {
              "type": "string"
            },
            "label": {
              "type": "string"
            },
            "source": {
              "type": "string"
            }
          }
        },
        "solutionScreenshotDriveId": {
          "type": "string",
          "description": "Google Drive ID for solution slide screenshot"
        }
      }
    },
    "quarter": {
      "type": "object",
      "description": "Single quarter roadmap data",
      "required": [
        "focus"
      ],
      "properties": {
        "focus": {
          "type": "string",
          "description": "Quarter focus area (short title)"
        },
        "theme": {
          "type": "string",
          "description": "Quarter theme (longer description)"
        },
        "phases": {
          "type": "array",
          "description": "Development phases active this quarter",
          "items": {
            "type": "string"
          }
        },
        "milestones": {
          "type": "array",
          "description": "Key milestones for this quarter",
          "items": {
            "$ref": "#/definitions/quarterMilestone"
          }
        },
        "deliverables": {
          "type": "array",
          "description": "Planned deliverables",
          "items": {
            "$ref": "#/definitions/deliverable"
          }
        },
        "metrics": {
          "type": "object",
          "description": "Target metrics for this quarter",
          "additionalProperties": true
        },
        "resources": {
          "type": "object",
          "description": "Resource allocation",
          "properties": {
            "team": {
              "type": [
                "integer",
                "string"
              ],
              "description": "Team size or range"
            },
            "budget": {
              "type": "string",
              "description": "Budget allocation"
            }
          },
          "additionalProperties": true
        },
        "risks": {
          "type": "array",
          "description": "Identified risks",
          "items": {
            "$ref": "#/definitions/risk"
          }
        },
        "dependencies": {
          "type": "array",
          "description": "Dependencies on other ventures or milestones",
          "items": {
            "$ref": "#/definitions/dependency"
          }
        },
        "erikHours": {
          "type": "integer",
          "minimum": 0,
          "maximum": 80,
          "description": "Erik's weekly hours allocated this quarter"
        },
        "status": {
          "type": "string",
          "description": "Quarter status: complete, active, or planned"
        },
        "version": {
          "type": "string",
          "description": "Version label for this quarter (e.g., 'v6.0')"
        },
        "versionLabel": {
          "type": "string",
          "description": "Human-readable version description"
        },
        "keyMilestone": {
          "type": "string",
          "description": "Primary milestone label for this quarter"
        },
        "icon": {
          "type": "string",
          "description": "Icon or emoji for quarter display"
        },
        "investorMetric": {
          "oneOf": [
            {
              "type": "string"
            },
            {
              "type": "object",
              "properties": {
                "value": {
                  "type": "string"
                },
                "label": {
                  "type": "string"
                }
              }
            }
          ],
          "description": "Investor-facing metric for this quarter (from T2)"
        }
      }
    },
    "quarterMilestone": {
      "type": "object",
      "description": "Milestone within a quarter",
      "required": [
        "event"
      ],
      "properties": {
        "date": {
          "type": "string",
          "format": "date",
          "description": "Target date (YYYY-MM-DD)"
        },
        "event": {
          "type": "string",
          "description": "Milestone name"
        },
        "gate": {
          "type": "boolean",
          "default": false,
          "description": "Is this a gate milestone?"
        },
        "critical": {
          "type": "boolean",
          "default": false,
          "description": "Is this critical path?"
        },
        "type": {
          "$ref": "https://schemas.luh.tech/_enums/luhtech-enums.schema.json#/definitions/milestoneType",
          "description": "Milestone category"
        }
      }
    },
    "deliverable": {
      "type": "object",
      "description": "Planned deliverable",
      "required": [
        "name"
      ],
      "properties": {
        "name": {
          "type": "string",
          "description": "Deliverable name"
        },
        "owner": {
          "type": "string",
          "default": "team",
          "description": "Person or team responsible"
        },
        "status": {
          "$ref": "https://schemas.luh.tech/_enums/luhtech-enums.schema.json#/definitions/deliverableStatus",
          "description": "Current status"
        },
        "priority": {
          "type": "integer",
          "minimum": 1,
          "maximum": 5,
          "description": "Priority (1=highest)"
        }
      }
    },
    "risk": {
      "type": "object",
      "description": "Identified risk",
      "required": [
        "risk"
      ],
      "properties": {
        "risk": {
          "type": "string",
          "description": "Risk description"
        },
        "probability": {
          "$ref": "https://schemas.luh.tech/_enums/luhtech-enums.schema.json#/definitions/riskLevel",
          "description": "Likelihood of occurrence"
        },
        "impact": {
          "$ref": "https://schemas.luh.tech/_enums/luhtech-enums.schema.json#/definitions/riskLevel",
          "description": "Impact if it occurs"
        },
        "mitigation": {
          "type": "string",
          "description": "Mitigation strategy"
        }
      }
    },
    "dependency": {
      "type": "object",
      "description": "Dependency on another venture or milestone",
      "required": [
        "type"
      ],
      "properties": {
        "type": {
          "$ref": "https://schemas.luh.tech/_enums/luhtech-enums.schema.json#/definitions/dependencyDirection",
          "description": "Dependency direction"
        },
        "ventureId": {
          "type": "string",
          "description": "Related venture ID"
        },
        "milestone": {
          "type": "string",
          "description": "Related milestone name"
        },
        "blocking": {
          "type": "boolean",
          "default": false,
          "description": "Is this a blocking dependency?"
        },
        "targetDate": {
          "type": "string",
          "format": "date",
          "description": "Expected completion date"
        }
      }
    },
    "financials": {
      "type": "object",
      "description": "Financial planning",
      "properties": {
        "preSeed": {
          "type": [
            "string",
            "null"
          ],
          "description": "Pre-seed funding amount"
        },
        "preSeedTiming": {
          "type": [
            "string",
            "null"
          ],
          "description": "Pre-seed timing (e.g., 'Q2 2026')"
        },
        "preSeedUse": {
          "type": "object",
          "description": "Pre-seed allocation breakdown",
          "additionalProperties": {
            "type": "string"
          }
        },
        "seed": {
          "type": [
            "string",
            "null"
          ],
          "description": "Seed funding amount"
        },
        "seedTiming": {
          "type": [
            "string",
            "null"
          ],
          "description": "Seed timing"
        },
        "burnRate": {
          "type": [
            "string",
            "null"
          ],
          "description": "Monthly burn rate"
        },
        "runway": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0,
          "description": "Runway in months"
        },
        "projections": {
          "type": "object",
          "description": "Annual projections by year",
          "patternProperties": {
            "^20[0-9]{2}$": {
              "type": "object",
              "properties": {
                "mrr": {
                  "type": "string"
                },
                "arr": {
                  "type": "string"
                },
                "customers": {
                  "type": [
                    "string",
                    "integer"
                  ]
                }
              }
            }
          }
        },
        "pricing": {
          "type": "object",
          "description": "Pricing model (T2)",
          "properties": {
            "tiers": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "tier": {
                    "type": "string"
                  },
                  "name": {
                    "type": "string"
                  },
                  "price": {
                    "type": [
                      "string",
                      "number",
                      "null"
                    ]
                  },
                  "displayPrice": {
                    "type": "string"
                  },
                  "acv": {
                    "type": [
                      "string",
                      "number",
                      "null"
                    ]
                  },
                  "description": {
                    "type": "string"
                  },
                  "tools": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  },
                  "toolCategories": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  },
                  "features": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        },
        "operatingModel": {
          "type": "object",
          "description": "Burn rate and runway as ComputedValue objects (T2)",
          "properties": {
            "burnRate": {
              "type": "object",
              "additionalProperties": true
            },
            "runway": {
              "type": "object",
              "additionalProperties": true
            }
          },
          "additionalProperties": true
        },
        "revenueModel": {
          "type": "object",
          "description": "Revenue metrics and projections (T2)",
          "properties": {
            "mrr": {
              "type": "object",
              "additionalProperties": true
            },
            "arr": {
              "type": "object",
              "additionalProperties": true
            },
            "projections": {
              "type": "object",
              "additionalProperties": true
            }
          },
          "additionalProperties": true
        },
        "unitEconomics": {
          "type": "object",
          "description": "Unit economics: CAC, LTV, margins (T2)",
          "properties": {
            "cac": {
              "type": "object",
              "additionalProperties": true
            },
            "ltv": {
              "type": "object",
              "additionalProperties": true
            },
            "ltvCacRatio": {
              "type": "object",
              "additionalProperties": true
            },
            "paybackPeriodMonths": {
              "type": "object",
              "additionalProperties": true
            },
            "grossMarginPercent": {
              "type": "object",
              "additionalProperties": true
            }
          },
          "additionalProperties": true
        },
        "burnForecast": {
          "type": "array",
          "description": "Monthly burn forecast for financials chart (T2)",
          "items": {
            "type": "object",
            "properties": {
              "month": {
                "type": "integer"
              },
              "label": {
                "type": "string"
              },
              "burn": {
                "type": "number"
              },
              "headcount": {
                "type": "integer"
              }
            }
          }
        },
        "revenueForecast": {
          "type": "array",
          "description": "Monthly revenue forecast for financials chart (T2)",
          "items": {
            "type": "object",
            "properties": {
              "month": {
                "type": "integer"
              },
              "contracts": {
                "type": "integer"
              },
              "mrr": {
                "type": "number"
              }
            }
          }
        },
        "hiringPlan": {
          "type": "array",
          "description": "Hiring plan for financials chart (T2)",
          "items": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string"
              },
              "role": {
                "type": "string"
              },
              "startMonth": {
                "type": "integer"
              },
              "monthlyCost": {
