{
  "$id": "https://schemas.luh.tech/follow-up-register.schema.json",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "additionalProperties": false,
  "definitions": {
    "FollowUpRecord": {
      "additionalProperties": false,
      "properties": {
        "blockedBy": {
          "description": "FU-ids or D-ids that must close before this FU can start. Empty array if unblocked.",
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "blocks": {
          "description": "FU-ids or named deliverables this FU must close before they can proceed.",
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "consumerRepo": {
          "description": "Repo that consumes or depends on the output of this FU",
          "type": "string"
        },
        "coordination": {
          "description": "Cross-repo or cross-agent coordination notes",
          "type": "string"
        },
        "estimate": {
          "description": "Rough execution estimate (e.g., '30 min', '1 session')",
          "type": "string"
        },
        "id": {
          "description": "Follow-up identifier. Either canonical (FU-TOPIC-SLUG-N) or grandfathered legacy (one-time enum).",
          "oneOf": [
            {
              "description": "Canonical convention: FU-<TOPIC-SLUG>-<N> where TOPIC-SLUG is uppercase, hyphen-separated, and N is a positive integer. All new FUs MUST match this pattern.",
              "pattern": "^FU-[A-Z][A-Z0-9-]*[A-Z0-9]-[0-9]+$",
              "type": "string"
            },
            {
              "description": "Legacy bare-number IDs grandfathered for migration. NO new entries may use this form. When the listed legacy IDs close, remove them from this enum.",
              "enum": [
                "FU-59"
              ],
              "type": "string"
            }
          ]
        },
        "opened": {
          "description": "Date the FU was registered (YYYY-MM-DD)",
          "format": "date",
          "type": "string"
        },
        "openedDuring": {
          "description": "Session or phase identifier during which this FU was surfaced (e.g., 'S-F3-CLOSE Phase 4', 'S-PORTFOLIO-CANON Phase B')",
          "type": "string"
        },
        "priority": {
          "description": "P0=blocks all downstream work, P1=blocks named items, P2=important but unblocked, P3=housekeeping",
          "enum": [
            "P0",
            "P1",
            "P2",
            "P3"
          ],
          "type": "string"
        },
        "relatedDecisions": {
          "description": "Decision IDs (d-YYYY-MM-DD-slug) associated with this FU. Distinct from blockedBy — this is associative reference (DEC informs the FU), not gating. Empty array if none.",
          "items": {
            "pattern": "^d-\\d{4}-\\d{2}-\\d{2}-[a-z0-9-]+$",
            "type": "string"
          },
          "type": "array"
        },
        "resolution": {
          "additionalProperties": false,
          "description": "Populated when status=closed",
          "properties": {
            "closedDate": {
              "format": "date",
              "type": "string"
            },
            "closedDuring": {
              "type": "string"
            },
            "commitSha": {
              "type": "string"
            },
            "prUrl": {
              "type": "string"
            },
            "summary": {
              "type": "string"
            }
          },
          "required": [
            "closedDate",
            "closedDuring",
            "summary"
          ],
          "type": "object"
        },
        "scope": {
          "description": "What must be done. Multi-sentence allowed.",
          "minLength": 10,
          "type": "string"
        },
        "status": {
          "enum": [
            "open",
            "in-progress",
            "blocked",
            "closed"
          ],
          "type": "string"
        },
        "title": {
          "maxLength": 200,
          "minLength": 5,
          "type": "string"
        },
        "trackingRepo": {
          "description": "Repo where execution work will land (e.g., 'luh-tech/Ectropy-Business')",
          "type": "string"
        }
      },
      "required": [
        "id",
        "title",
        "priority",
        "status",
        "opened",
        "openedDuring",
        "scope",
        "blockedBy",
        "blocks"
      ],
      "type": "object"
    }
  },
  "description": "Schema for tracking follow-up items, decisions, open work, and deferred actions within a venture's .roadmap/follow-up-register.json. Adopted portfolio-wide to standardize how ventures track in-flight work that doesn't yet warrant a milestone or decision-log entry.",
  "properties": {
    "$id": {
      "type": "string"
    },
    "$schema": {
      "type": "string"
    },
    "followUps": {
      "items": {
        "$ref": "#/definitions/FollowUpRecord"
      },
      "type": "array"
    },
    "indexes": {
      "additionalProperties": false,
      "properties": {
        "byBlockedBy": {
          "additionalProperties": {
            "items": {
              "type": "string"
            },
            "type": "array"
          },
          "description": "Maps each FU-id to the list of FU-ids that have this FU in their blockedBy[] field. Derived from followUps[].blockedBy. Answers: 'What unblocks when this FU closes?'",
          "type": "object"
        },
        "byPriority": {
          "additionalProperties": false,
          "properties": {
            "P0": {
              "items": {
                "type": "string"
              },
              "type": "array"
            },
            "P1": {
              "items": {
                "type": "string"
              },
              "type": "array"
            },
            "P2": {
              "items": {
                "type": "string"
              },
              "type": "array"
            },
            "P3": {
              "items": {
                "type": "string"
              },
              "type": "array"
            }
          },
          "type": "object"
        },
        "byStatus": {
          "additionalProperties": false,
          "properties": {
            "blocked": {
              "items": {
                "type": "string"
              },
              "type": "array"
            },
            "closed": {
              "items": {
                "type": "string"
              },
              "type": "array"
            },
            "in-progress": {
              "items": {
                "type": "string"
              },
              "type": "array"
            },
            "open": {
              "items": {
                "type": "string"
              },
              "type": "array"
            }
          },
          "type": "object"
        }
      },
      "required": [
        "byPriority",
        "byStatus",
        "byBlockedBy"
      ],
      "type": "object"
    },
    "lastUpdated": {
      "format": "date-time",
      "type": "string"
    },
    "meta": {
      "additionalProperties": false,
      "properties": {
        "byPriority": {
          "additionalProperties": false,
          "description": "Summary counts of FUs grouped by priority. Distinct from indexes.byPriority which holds full id lists.",
          "properties": {
            "P0": {
              "minimum": 0,
              "type": "integer"
            },
            "P1": {
              "minimum": 0,
              "type": "integer"
            },
            "P2": {
              "minimum": 0,
              "type": "integer"
            },
            "P3": {
              "minimum": 0,
              "type": "integer"
            }
          },
          "type": "object"
        },
        "byStatus": {
          "additionalProperties": false,
          "description": "Summary counts of FUs grouped by status. Distinct from indexes.byStatus which holds full id lists.",
          "properties": {
            "blocked": {
              "minimum": 0,
              "type": "integer"
            },
            "closed": {
              "minimum": 0,
              "type": "integer"
            },
            "in-progress": {
              "minimum": 0,
              "type": "integer"
            },
            "open": {
              "minimum": 0,
              "type": "integer"
            }
          },
          "type": "object"
        },
        "sourceOfTruth": {
          "type": "string"
        },
        "totalCount": {
          "minimum": 0,
          "type": "integer"
        }
      },
      "required": [
        "sourceOfTruth",
        "totalCount"
      ],
      "type": "object"
    },
    "schemaVersion": {
      "description": "Schema version of this register (SemVer). Allows independent versioning per venture.",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "type": "string"
    },
    "ventureId": {
      "description": "Venture identifier (lowercase kebab-case; matches the venture's repo naming convention).",
      "pattern": "^[a-z][a-z0-9-]*$",
      "type": "string"
    },
    "version": {
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$",
      "type": "string"
    }
  },
  "required": [
    "$schema",
    "$id",
    "schemaVersion",
    "version",
    "ventureId",
    "lastUpdated",
    "meta",
    "followUps",
    "indexes"
  ],
  "title": "Follow-Up Register",
  "type": "object",
  "version": "1.1.0"
}
