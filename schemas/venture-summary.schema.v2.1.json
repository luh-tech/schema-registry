{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "urn:luhtech:schema:venture-summary:v2.1",
  "title": "Venture Summary v2.1",
  "description": "DERIVED ARTIFACT — DO NOT EDIT MANUALLY. Generated by luhtech-transform from roadmap.json + roadmap-business.json + domains.json. Any manual edits will be overwritten on next transform run. To update this file, edit the canonical sources and re-run: luhtech-transform run --transform venture-summary-full. v2.1.0: adds webPresence block derived from .roadmap/domains.json.",
  "type": "object",
  "required": [
    "$schema",
    "version",
    "venture",
    "pitch",
    "metrics",
    "meta"
  ],
  "properties": {
    "$schema": {
      "type": "string",
      "enum": [
        "https://luhtech.dev/schemas/venture-summary.json",
        "https://luhtech.dev/schemas/venture-summary-v1.json",
        "urn:luhtech:schema:venture-summary:v2.0",
        "urn:luhtech:schema:venture-summary:v2.1"
      ]
    },
    "version": {
      "$ref": "https://luhtech.dev/schemas/enums.json#/definitions/semver"
    },
    "lastUpdated": {
      "type": "string",
      "format": "date-time"
    },
    "venture": {
      "$ref": "#/definitions/ventureIdentity"
    },
    "pitch": {
      "$ref": "#/definitions/pitchDeck"
    },
    "metrics": {
      "$ref": "#/definitions/currentMetrics"
    },
    "team": {
      "$ref": "#/definitions/teamInfo"
    },
    "funding": {
      "$ref": "#/definitions/fundingInfo"
    },
    "milestones": {
      "type": "object",
      "description": "Milestone data",
      "additionalProperties": true
    },
    "assets": {
      "$ref": "#/definitions/brandAssets"
    },
    "webPresence": {
      "type": "object",
      "description": "Web presence summary derived by transform from .roadmap/domains.json. NEVER manually authored.",
      "required": ["primaryDomain", "productionUrl", "totalDomains", "migrationStatus"],
      "additionalProperties": false,
      "properties": {
        "primaryDomain": {
          "type": "string",
          "format": "hostname",
          "description": "Primary brand domain"
        },
        "productionUrl": {
          "type": "string",
          "format": "uri",
          "description": "Production URL"
        },
        "totalDomains": {
          "type": "integer",
          "minimum": 1,
          "description": "Total domains owned by this venture"
        },
        "migrationStatus": {
          "type": "string",
          "enum": ["none", "pending", "partial", "ready", "complete", "blocked"],
          "description": "Cloudflare migration status"
        },
        "verticalEntryPoints": {
          "type": "array",
          "description": "Market vertical entry point URLs",
          "items": {
            "type": "object",
            "required": ["url", "vertical"],
            "properties": {
              "url": { "type": "string", "format": "uri" },
              "vertical": { "type": "string" },
              "status": { "type": "string" }
            }
          }
        },
        "subBrandCount": {
          "type": "integer",
          "minimum": 0,
          "description": "Number of named sub-brands under this venture"
        },
        "hasOpenCommunity": {
          "type": "boolean",
          "description": "Whether this venture has an open community domain namespace"
        },
        "cloudflareAccountPost": {
          "type": "string",
          "description": "Target CF account after migration"
        },
        "positioning": {
          "type": "string",
          "description": "One-line positioning from url-catalog.json"
        }
      }
    },
    "meta": {
      "type": "object",
      "description": "GENERATED ARTIFACT. Do not edit manually. Regenerate using luhtech-transform.",
      "required": [
        "generatedAt",
        "sourceHash",
        "transformId",
        "transformVersion",
        "generatedFrom"
      ],
      "properties": {
        "generatedAt": {
          "type": "string",
          "format": "date-time"
        },
        "sourceHash": {
          "type": "object",
          "required": [
            "t1",
            "t2"
          ],
          "properties": {
            "t1": {
              "type": "string",
              "pattern": "^sha256:[a-f0-9]{64}$"
            },
            "t2": {
              "type": "string",
              "pattern": "^sha256:[a-f0-9]{64}$"
            }
          }
        },
        "transformId": {
          "type": "string",
          "format": "uri"
        },
        "transformVersion": {
          "type": "string",
          "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
        },
        "generatedFrom": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1
        }
      }
    },
    "ventureId": {
      "type": "string",
      "description": "Venture identifier"
    },
    "ventureName": {
      "type": "string",
      "description": "Venture display name"
    },
    "identity": {
      "type": "object",
      "description": "Venture identity fields (mission, vision, stage)",
      "properties": {
        "mission": {
          "type": "string"
        },
        "vision": {
          "type": "string"
        },
        "currentStage": {
          "type": "string"
        }
      }
    },
    "status": {
      "type": "object",
      "description": "Venture status fields",
      "properties": {
        "currentPhase": {
          "type": "string"
        },
        "blockedBy": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "financials": {
      "type": "object",
      "description": "Financial data from roadmap-business.json",
      "additionalProperties": true
    },
    "competitive": {
      "type": "object",
      "description": "Competitive data from roadmap-business.json",
      "additionalProperties": true
    }
  },
  "definitions": {
    "ventureIdentity": {
      "type": "object",
      "required": [
        "id",
        "name",
        "tagline",
        "stage"
      ],
      "properties": {
        "id": {
          "$ref": "https://luhtech.dev/schemas/enums.json#/definitions/ventureIdPattern"
        },
        "name": {
          "type": "string",
          "maxLength": 100
        },
        "tagline": {
          "type": "string",
          "maxLength": 100
        },
        "stage": {
          "$ref": "https://luhtech.dev/schemas/enums.json#/definitions/ventureStage"
        },
        "founded": {
          "type": "string",
          "format": "date"
        },
        "domain": {
          "type": "string",
          "format": "hostname"
        },
        "industry": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "location": {
          "type": "string"
        }
      }
    },
    "pitchDeck": {
      "type": "object",
      "required": [
        "problem",
        "solution",
        "market",
        "businessModel",
        "differentiator"
      ],
      "properties": {
        "problem": {
          "$ref": "#/definitions/slideContent"
        },
        "solution": {
          "$ref": "#/definitions/slideContent"
        },
        "market": {
          "$ref": "#/definitions/marketSlide"
        },
        "businessModel": {
          "$ref": "#/definitions/businessModelSlide"
        },
        "differentiator": {
          "$ref": "#/definitions/slideContent"
        },
        "traction": {
          "$ref": "#/definitions/tractionSlide"
        },
        "ask": {
          "$ref": "#/definitions/askSlide"
        },
        "timeline": {
          "$ref": "#/definitions/timelineSlide"
        }
      }
    },
    "slideContent": {
      "type": "object",
      "required": [
        "headline"
      ],
      "properties": {
        "headline": {
          "type": "string",
          "maxLength": 100
        },
        "subheadline": {
          "type": "string",
          "maxLength": 200
        },
        "bullets": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "maxItems": 5
        },
        "narrative": {
          "type": "string",
          "maxLength": 500
        }
      }
    },
    "marketSlide": {
      "type": "object",
      "required": [
        "tam",
        "sam",
        "som"
      ],
      "properties": {
        "headline": {
          "type": "string"
        },
        "tam": {
          "type": "object",
          "properties": {
            "value": {
              "type": "string"
            },
            "description": {
              "type": "string"
            }
          }
        },
        "sam": {
          "type": "object",
          "properties": {
            "value": {
              "type": "string"
            },
            "description": {
              "type": "string"
            }
          }
        },
        "som": {
          "type": "object",
          "properties": {
            "value": {
              "type": "string"
            },
            "description": {
              "type": "string"
            }
          }
        },
        "growthRate": {
          "type": "string"
        },
        "trends": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "businessModelSlide": {
      "type": "object",
      "required": [
        "revenueModel"
      ],
      "properties": {
        "headline": {
          "type": "string"
        },
        "revenueModel": {
          "type": "string"
        },
        "pricing": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "tier": {
                "type": "string"
              },
              "price": {
                "type": "string"
              },
              "features": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            }
          }
        },
        "unitEconomics": {
          "type": "object",
          "properties": {
            "cac": {
              "type": "string"
            },
            "ltv": {
              "type": "string"
            },
            "paybackPeriod": {
              "type": "string"
            },
            "grossMargin": {
              "type": "string"
            }
          }
        }
      }
    },
    "tractionSlide": {
      "type": "object",
      "properties": {
        "headline": {
          "type": "string"
        },
        "metrics": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "label": {
                "type": "string"
              },
              "value": {
                "type": "string"
              },
              "trend": {
                "$ref": "https://luhtech.dev/schemas/enums.json#/definitions/trend"
              }
            }
          }
        },
        "customers": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "testimonials": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "quote": {
                "type": "string"
              },
              "author": {
                "type": "string"
              },
              "company": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "askSlide": {
      "type": "object",
      "required": [
        "amount"
      ],
      "properties": {
        "headline": {
          "type": "string"
        },
        "amount": {
          "type": "string"
        },
        "useOfFunds": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "category": {
                "type": "string"
              },
              "percentage": {
                "type": "integer"
              },
              "description": {
                "type": "string"
              }
            }
          }
        },
        "milestones": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "timelineSlide": {
      "type": "object",
      "properties": {
        "headline": {
          "type": "string"
        },
        "milestones": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "date": {
                "type": "string",
                "format": "date"
              },
              "label": {
                "type": "string"
              },
              "status": {
                "$ref": "https://luhtech.dev/schemas/enums.json#/definitions/milestoneStatus"
              }
            }
          }
        }
      }
    },
    "currentMetrics": {
      "type": "object",
      "properties": {
        "mrr": {
          "type": "string"
        },
        "arr": {
          "type": "string"
        },
        "customers": {
          "type": "integer"
        },
        "users": {
          "type": "integer"
        },
        "growth": {
          "type": "string"
        },
        "nps": {
          "type": "integer"
        },
        "churn": {
          "type": "string"
        },
        "custom": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "teamInfo": {
      "type": "object",
      "properties": {
        "size": {
          "type": "integer"
        },
        "founders": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/teamMember"
          }
        },
        "advisors": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/teamMember"
          }
        },
        "keyHires": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "teamMember": {
      "type": "object",
      "required": [
        "name",
        "role"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "role": {
          "type": "string"
        },
        "bio": {
          "type": "string"
        },
        "linkedin": {
          "type": "string",
          "format": "uri"
        },
        "image": {
          "type": "string",
          "format": "uri"
        }
      }
    },
    "fundingInfo": {
      "type": "object",
      "properties": {
        "totalRaised": {
          "type": "string"
        },
        "currentRound": {
          "type": "object",
          "properties": {
            "type": {
              "type": "string"
            },
            "target": {
              "type": "string"
            },
            "raised": {
              "type": "string"
            },
            "status": {
              "$ref": "https://luhtech.dev/schemas/enums.json#/definitions/fundingStatus"
            }
          }
        },
        "investors": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "runway": {
          "type": "integer"
        }
      }
    },
    "milestonesSummary": {
      "type": "object",
      "properties": {
        "achieved": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "date": {
                "type": "string",
                "format": "date"
              },
              "milestone": {
                "type": "string"
              }
            }
          }
        },
        "upcoming": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "date": {
                "type": "string",
                "format": "date"
              },
              "milestone": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "brandAssets": {
      "type": "object",
      "properties": {
        "logo": {
          "type": "object",
          "properties": {
            "primary": {
              "type": "string"
            },
            "light": {
              "type": "string"
            },
            "dark": {
              "type": "string"
            },
            "icon": {
              "type": "string"
            }
          }
        },
        "colors": {
          "type": "object",
          "properties": {
            "primary": {
              "$ref": "https://luhtech.dev/schemas/enums.json#/definitions/hexColor"
            },
            "secondary": {
              "$ref": "https://luhtech.dev/schemas/enums.json#/definitions/hexColor"
            },
            "accent": {
              "$ref": "https://luhtech.dev/schemas/enums.json#/definitions/hexColor"
            }
          }
        },
        "fonts": {
          "type": "object",
          "properties": {
            "heading": {
              "type": "string"
            },
            "body": {
              "type": "string"
            }
          }
        },
        "backgrounds": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "provenanceMeta": {
      "type": "object",
      "description": "GENERATED ARTIFACT. Do not edit manually. Regenerate using luhtech-transform.",
      "required": [
        "generatedAt",
        "sourceHash",
        "transformId",
        "transformVersion",
        "generatedFrom"
      ],
      "properties": {
        "generatedAt": {
          "type": "string",
          "format": "date-time",
          "description": "ISO 8601 timestamp when transform ran"
        },
        "sourceHash": {
          "type": "object",
          "required": [
            "t1",
            "t2"
          ],
          "description": "SHA-256 hashes of source files at transform time",
          "properties": {
            "t1": {
              "type": "string",
              "pattern": "^sha256:[a-f0-9]{64}$",
              "description": "SHA-256 of roadmap.json at run time"
            },
            "t2": {
              "type": [
                "string",
                "null"
              ],
              "description": "SHA-256 of roadmap-business.json at run time"
            }
          }
        },
        "transformId": {
          "type": "string",
          "description": "URN of the transform template used"
        },
        "transformVersion": {
          "type": "string",
          "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$",
          "description": "SemVer of the transform template"
        },
        "generatedFrom": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1,
          "description": "List of source file names used to generate this artifact"
        }
      }
    }
  },
  "x-changelog": [
    {
      "version": "2.1.0",
      "date": "2026-02-28",
      "changes": [
        "Added webPresence block — derived from domains.json via venture-summary-full transform",
        "Replaces single domain string field with full web presence summary",
        "Enables dashboard-kpi and deck-data transforms to surface domain data without parsing domains.json",
        "Part of LUHTECH-DEVPROMPT-DOMAIN-001 domain catalog integration"
      ]
    },
    {
      "version": "2.0.0",
      "date": "2026-02-26",
      "changes": [
        "Added required provenance meta block (generatedAt, sourceHash, transformId, transformVersion, generatedFrom)",
        "DERIVED ARTIFACT — Do not edit manually. Regenerate using luhtech-transform.",
        "Source: Transform Fabric Architecture v2.0.0"
      ]
    }
  ]
}
